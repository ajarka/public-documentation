    classDef cabang fill:#b45309,stroke:#92400e,color:#fff;
    classDef ranting fill:#15803d,stroke:#166534,color:#fff;
    classDef agen fill:#0e7490,stroke:#155e75,color:#fff;
    classDef jamaah fill:#fef3c7,stroke:#d97706,color:#78350f;

    class PUSAT pusat;
    class KAB kab;
    class CABANG cabang;
    class RANTING ranting;
    class AGEN agen;
    class JAMAAH jamaah;
